        "@fastify/rate-limit": "^10.1.1",
        "@prisma/client": "^6.0.0",
        "@types/uuid": "^10.0.0",
        "argon2": "^0.41.1",
        "dotenv": "^16.4.5",
        "fastify": "^5.0.0",
        "pino": "^9.4.0",
        "pino-pretty": "^11.2.2",
        "uuid": "^13.0.0",
        "zod": "^3.23.8"
