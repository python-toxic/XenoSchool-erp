// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Authentication & Authorization ────────────────────────────

enum Role {
  super_admin
  admin
  principal
  teacher
  accountant
  parent
  student
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String         @map("password_hash")
  firstName     String         @map("first_name")
  lastName      String         @map("last_name")
  isActive      Boolean        @default(true) @map("is_active")
  lastLogin     DateTime?      @map("last_login")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  roles         UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  // Realizations
  student       Student?
  teacher     Teacher?
  parent        Parent?

  @@map("users")
}

model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  role   Role
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Academic ──────────────────────────────────────────────────

model Student {
  id              String   @id @default(uuid())
  admissionNumber String   @unique @map("admission_number")
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  dateOfBirth     DateTime @map("dob")
  gender          String
  email           String?
  phone           String?
  address         String?
  isActive        Boolean  @default(true) @map("is_active")
  enrollmentDate  DateTime @default(now()) @map("enrollment_date")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  // Extended Info
  fatherName      String?  @map("father_name")
  motherName      String?  @map("mother_name")
  emergencyPhone  String?  @map("emergency_phone")
  previousSchool  String?  @map("previous_school")
  medicalInfo     String?  @map("medical_info")
  otherInfo       String?  @map("other_info")


  // Link to User for auth
  userId String? @unique @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  classId   String   @map("class_id")
  class     Class    @relation(fields: [classId], references: [id])
  sectionId String   @map("section_id")
  section   Section  @relation(fields: [sectionId], references: [id])
  parentId  String?  @map("parent_id")
  parent    Parent?  @relation(fields: [parentId], references: [id])

  attendance AttendanceRecord[]
  grades     Grade[]
  invoices   FeeInvoice[]
  payments   Payment[]
  documents  StudentDocument[]


  @@map("students")
}

model Teacher {
  id             String   @id @default(uuid())
  employeeId     String   @unique @map("employee_id")
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  department     String
  qualification  String?
  dateOfJoining  DateTime @default(now()) @map("date_of_joining")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Link to User for auth
  userId String? @unique @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  sections Section[] @relation("ClassTeacher")

  @@map("teachers")
}

model Parent {
  id        String   @id @default(uuid())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  phone     String
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Link to User for auth
  userId String? @unique @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  students Student[]

  @@map("parents")
}

model Class {
  id           String    @id @default(uuid())
  name         String
  grade        Int
  academicYear String    @map("academic_year")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  sections     Section[]
  students     Student[]

  @@unique([name])
  @@map("classes")
}

model Section {
  id             String   @id @default(uuid())
  name           String
  capacity       Int
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  classId        String   @map("class_id")
  class          Class    @relation(fields: [classId], references: [id])
  classTeacherId String?  @map("class_teacher_id")
  classTeacher   Teacher? @relation("ClassTeacher", fields: [classTeacherId], references: [id])

  students Student[]

  @@unique([name, classId])
  @@map("sections")
}

// ─── Operations ───────────────────────────────────────────────

model AttendanceRecord {
  id        String           @id @default(uuid())
  date      DateTime
  status    AttendanceStatus
  markedBy  String           @map("marked_by")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  studentId String  @map("student_id")
  student   Student @relation(fields: [studentId], references: [id])

  @@map("attendance_records")
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

model Exam {
  id           String   @id @default(uuid())
  name         String
  type         ExamType
  subject      String
  date         DateTime
  totalMarks   Int      @map("total_marks")
  passingMarks Int      @map("passing_marks")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  grades Grade[]

  @@map("exams")
}

enum ExamType {
  midterm
  final
  quiz
  assignment
}

model Grade {
  id            String   @id @default(uuid())
  marksObtained Float    @map("marks_obtained")
  grade         String
  gradedBy      String   @map("graded_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  examId    String  @map("exam_id")
  exam      Exam    @relation(fields: [examId], references: [id])
  studentId String  @map("student_id")
  student   Student @relation(fields: [studentId], references: [id])

  @@map("grades")
}

// ─── Finance ──────────────────────────────────────────────────

model FeeInvoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique @map("invoice_number")
  amount        Float
  dueDate       DateTime      @map("due_date")
  status        InvoiceStatus
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  studentId String    @map("student_id")
  student   Student   @relation(fields: [studentId], references: [id])
  payments  Payment[]

  @@map("fee_invoices")
}

enum InvoiceStatus {
  pending
  paid
  overdue
  partial
}

model Payment {
  id            String        @id @default(uuid())
  amount        Float
  paymentDate   DateTime      @default(now()) @map("payment_date")
  paymentMethod PaymentMethod @map("payment_method")
  transactionId String?       @map("transaction_id")
  receivedBy    String        @map("received_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  invoiceId String     @map("invoice_id")
  invoice   FeeInvoice @relation(fields: [invoiceId], references: [id])
  studentId String     @map("student_id")
  student   Student    @relation(fields: [studentId], references: [id])

  @@map("payments")
}

enum PaymentMethod {
  cash
  bank_transfer
  online
  cheque
}

// ─── Communication ─────────────────────────────────────────────

model Announcement {
  id          String               @id @default(uuid())
  title       String
  content     String
  priority    AnnouncementPriority
  targetRoles Role[]               @map("target_roles")
  isPublished Boolean              @default(false) @map("is_published")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  @@map("announcements")
}

enum AnnouncementPriority {
  low
  medium
  high
  urgent
}

// ─── System ────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  details    Json
  ipAddress  String   @map("ip_address")
  userAgent  String   @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model StudentDocument {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      String   // e.g., 'PassportPhoto', 'BirthCertificate', 'GradeReport'
  name      String   // Display name
  url       String   // Cloud storage URL
  createdAt DateTime @default(now()) @map("created_at")

  @@map("student_documents")
}

